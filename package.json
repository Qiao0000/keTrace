{
  "name": "ketrace",
  "version": "0.1.0",
  "description": "KeTrace — local-first activity, task, thesis and report workbench.",
  "author": "mymac",
  "license": "MIT",
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "/Users/mymac/Claude/bin/node scripts/build-native.mjs && /Users/mymac/Downloads/PawPal/node_modules/.bin/electron-vite dev",
    "build": "/Users/mymac/Claude/bin/node scripts/clean-out.mjs && /Users/mymac/Downloads/PawPal/node_modules/.bin/electron-vite build && /Users/mymac/Claude/bin/node scripts/build-native.mjs",
    "typecheck": "/Users/mymac/Downloads/PawPal/node_modules/.bin/tsc --noEmit",
    "dist:mac": "ELECTRON_BUILDER_SKIP_SIGN=true /Users/mymac/Downloads/PawPal/node_modules/.bin/electron-builder --mac --arm64 --config.electronDist=node_modules/electron/dist --config.electronVersion=$(cat node_modules/electron/dist/version)",
    "dist:mac-arm64": "ELECTRON_BUILDER_SKIP_SIGN=true /Users/mymac/Downloads/PawPal/node_modules/.bin/electron-builder --mac --arm64 --config.electronDist=node_modules/electron/dist --config.electronVersion=$(cat node_modules/electron/dist/version)",
    "dist:win": "/Users/mymac/Downloads/PawPal/node_modules/.bin/electron-builder --win"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^13.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "com.ketrace.app",
    "productName": "刻迹",
    "artifactName": "${productName}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icons/icon.icns",
      "extendInfo": {
        "CFBundleIconFile": "icon.icns",
        "CFBundleIconName": "icon",
        "CFBundleDisplayName": "刻迹",
        "CFBundleName": "刻迹"
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null
    },
    "win": {
      "icon": "resources/icons/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "out/native",
        "to": "native",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "out/**/*",
      "!**/.DS_Store"
    ]
  }
}
